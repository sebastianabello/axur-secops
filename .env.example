# ==========================================================================
# axur-secops — Variables de entorno
# Sistema de sincronización Axur Digital Risk Protection → Google SecOps
# ==========================================================================

# ==========================================================================
# AXUR API
# Obtener en: https://one.axur.com/preferences?tab=api-keys
# ==========================================================================
AXUR_API_KEY=your_axur_api_key_here

# CustomerKeys a sincronizar (separados por coma, sin espacios)
# Dejar vacío = sincroniza todos los customers del tenant Axur
AXUR_CUSTOMERS=CLIENTE1

# Timezone para las consultas (formato UTC offset)
TIMEZONE=-05:00

# Timeout HTTP para llamadas a Axur (segundos)
API_TIMEOUT=30

# Enmascarar contraseñas en credentials (true/false)
MASK_PASSWORDS=true


# ==========================================================================
# GOOGLE SECOPS — Configuración común (requerida en TODOS los modos)
# ==========================================================================

# GCP Project ID donde está el tenant de Chronicle
CHRONICLE_PROJECT_ID=my-gcp-project-id

# Región del tenant de Chronicle
# Opciones: us | europe | asia-southeast1 | me-central1
CHRONICLE_REGION=us

# UUID del tenant de Chronicle
# Dónde encontrarlo: SIEM UI → Settings → Profile → Instance ID
CHRONICLE_INSTANCE_ID=00000000-0000-0000-0000-000000000000

# Modo de autenticación con Google SecOps
# Opciones:
#   webhook  → API Key + Secret de feeds HTTPS configurados en SecOps UI  [RECOMENDADO]
#   sa_file  → Service Account JSON en disco
#   sa_env   → Service Account JSON en variable de entorno (base64 o raw)
CHRONICLE_AUTH_MODE=webhook


# ==========================================================================
# MODO PRINCIPAL: Webhook Feed (CHRONICLE_AUTH_MODE=webhook)
#
# Crea DOS feeds en SecOps UI (uno por log type):
#
#   Feed 1 — Tickets:
#     Settings → Feeds → Add Feed → HTTPS Webhook
#     Log Type: AXUR_DRP_TICKETS_CUSTOM
#     → Copiar Feed ID, API Key y Webhook Secret → pegar abajo en TICKETS_*
#
#   Feed 2 — Credentials:
#     Settings → Feeds → Add Feed → HTTPS Webhook
#     Log Type: AXUR_DRP_CREDENTIALS_CUSTOM
#     → Copiar Feed ID, API Key y Webhook Secret → pegar abajo en CREDS_*
#
# Cada feed genera su propio par único de API Key + Webhook Secret al crearse.
# NO uses las mismas credenciales para los dos feeds.
# ==========================================================================

# --- Feed de TICKETS ---
CHRONICLE_TICKETS_FEED_ID=00000000-0000-0000-0000-000000000000
CHRONICLE_TICKETS_API_KEY=AIzaSy...
CHRONICLE_TICKETS_WEBHOOK_SECRET=abc123...

# --- Feed de CREDENTIALS ---
CHRONICLE_CREDS_FEED_ID=00000000-0000-0000-0000-111111111111
CHRONICLE_CREDS_API_KEY=AIzaSy...
CHRONICLE_CREDS_WEBHOOK_SECRET=xyz789...


# ==========================================================================
# ALTERNATIVA: Service Account (CHRONICLE_AUTH_MODE=sa_file o sa_env)
# Solo necesario si no usas el modo webhook.
# ==========================================================================

# sa_file: Ruta al archivo JSON de la Service Account
# CHRONICLE_SA_KEY_FILE=/secrets/chronicle-sa-key.json
# CHRONICLE_FORWARDER_ID=00000000-0000-0000-0000-000000000000

# sa_env: JSON de la SA como variable de entorno (raw o base64)
# Codificar: base64 -w0 chronicle-sa-key.json
# CHRONICLE_SA_KEY_JSON=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50IiwicHJvamVjdF9pZCI6Ii4uLiJ9...
# CHRONICLE_FORWARDER_ID=00000000-0000-0000-0000-000000000000


# ==========================================================================
# ESTADO DE SINCRONIZACIÓN
# ==========================================================================
STATE_FILE=sync_state.json

# ==========================================================================
# LOGGING
# ==========================================================================
LOG_LEVEL=INFO
